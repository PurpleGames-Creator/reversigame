# --- クライアント（Next.js / Vercel）---
# socket.io サーバ（バックエンド）の公開URL。未設定なら purple-reversi.up.railway.app にフォールバック。
NEXT_PUBLIC_SOCKET_URL=https://purple-reversi.up.railway.app

# （旧・未使用）REST API を使う場合のベースURL
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- サーバ（socket.io / Railway 等）---
# 許可するフロントのオリジン（カンマ区切り）。未設定なら localhost と *.vercel.app を自動許可。
# 例: CLIENT_ORIGIN=https://reversi.example.com,https://reversigame.vercel.app
# CLIENT_ORIGIN=
